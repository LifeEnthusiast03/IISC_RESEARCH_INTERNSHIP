# =============================================================
# LARGE DATA FILES — do not push to GitHub
# =============================================================

# Allow .gitkeep placeholder files through in all data folders
# (these are empty files that preserve folder structure in git)
!data/**/.gitkeep
!models/.gitkeep

# CICIDS2017 — benign traffic CSVs (data/cicids2017/benign_data/)
data/cicids2017/benign_data/*.csv
data/cicids2017/benign_data/*.png

# CICIDS2017 — attack traffic CSVs (data/cicids2017/attack_data/)
data/cicids2017/attack_data/*.csv
data/cicids2017/attack_data/*.png

# CICIDS2017 — any leftover files at the top level of cicids2017/
data/cicids2017/*.csv
data/cicids2017/*.png

# UNSW-NB15 raw CSVs
data/unsw_nb15/*.csv

# Catch-all safety net — block ALL data file types anywhere under data/
data/**/*.csv
data/**/*.png
data/**/*.jpg
data/**/*.jpeg
data/**/*.npy
data/**/*.npz
data/**/*.pkl
data/**/*.pt
data/**/*.h5
data/**/*.parquet

# Preprocessed NumPy arrays and artefacts (data/processed/)
data/processed/*.npy
data/processed/*.pkl
data/processed/*.json

# Trained model artefacts (models/)
models/*.pt
models/*.pkl
models/*.h5

# =============================================================
# LOCAL-ONLY TEST FOLDER — do not push to GitHub
# =============================================================
# tests/ is a local scratch space for quick model evaluation.
# It contains no production code and should stay off the remote.
tests/
